# Convex
NEXT_PUBLIC_CONVEX_SITE_URL=
NEXT_PUBLIC_CONVEX_URL=

# Internal API (shared secret between Next.js and Convex HTTP endpoints)
INTERNAL_API_SECRET=

# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# AI Providers
GOOGLE_GENERATIVE_AI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Telegram Bot (for Mini App initData verification)
TELEGRAM_BOT_TOKEN=

# 360dialog (WhatsApp Cloud API — dormant)
DIALOG360_API_KEY=
WHATSAPP_NUMBER=+971542022073

# PostHog
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
POSTHOG_PERSONAL_API_KEY=
POSTHOG_PROJECT_ID=

# CloudConvert (document processing)
CLOUDCONVERT_API_KEY=

# Google Tag Manager (optional — leave empty to disable)
NEXT_PUBLIC_GTM_ID=

# Google Analytics 4 + Google Ads (direct gtag.js — runs alongside GTM)
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_GADS_ID=
# Full conversion label from Google Ads (format: AW-XXXXXXXXXX/XXXXXXXXXXXX)
NEXT_PUBLIC_GADS_CONVERSION_LABEL=

# --- Convex-only env vars (set via `npx convex env set`) ---
# BASE_URL=                  # App base URL (https://ghali.ae in prod, http://localhost:3000 in dev)
# CONVEX_SITE_URL=           # Public-facing Convex HTTP URL
# INTERNAL_API_SECRET=       # Same value as above
# CLERK_WEBHOOK_SECRET=      # Clerk webhook signature secret
# GOOGLE_GENERATIVE_AI_API_KEY=
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# DIALOG360_API_KEY=         # 360dialog WhatsApp Cloud API key
# WHATSAPP_NUMBER=           # Ghali's WhatsApp number (+971542022073)
# WEBHOOK_VERIFY_TOKEN=      # Verification token for webhook setup
# WEBHOOK_SECRET=            # Optional: HMAC secret for webhook signature validation
# TELEGRAM_BOT_TOKEN=       # Bot token for initData verification (same as bot server)
# WEBAPP_BASE_URL=          # Mini App base URL (https://ghali.ae in prod, http://localhost:3000 in dev)
# CLOUDCONVERT_API_KEY=
